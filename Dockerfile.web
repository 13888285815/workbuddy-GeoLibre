# GeoLibre Web UI Dockerfile

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y gcc && rm -rf /var/lib/apt/lists/*

# Copy everything needed
COPY python /app/python
COPY web-ui.html /app/web-ui.html

# Install Python package + web dependencies
RUN pip install --no-cache-dir -e /app/python && \
    pip install --no-cache-dir fastapi uvicorn python-multipart

# Copy static HTML into package directory so web_app.py finds it
RUN cp /app/web-ui.html /app/python/src/geolibre/static/index.html

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/api/health')" || exit 1

CMD ["python", "-m", "geolibre.web_app", "--host", "0.0.0.0", "--port", "8000"]
